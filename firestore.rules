rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isAuth() { return request.auth != null; }

    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.email in ['amir@emf.com', 'khaled@emf.com', 'youssef@emf.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')
      );
    }

    function isAdmin() {
      return isAuth() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'agent'])
      );
    }

    function isOwner(userId: string) {
      return isAuth() && request.auth.uid == userId;
    }

    function isMember(uid: string) {
      return isAuth() && request.auth.uid in resource.data.members;
    }

    function isNotBlocked() {
      return !(exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'blocked');
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuth() && isNotBlocked();
      allow create: if isAuth() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if isAuth() && isNotBlocked() && (
        isSuperAdmin() ||
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status)
      );
      allow delete: if isSuperAdmin();
    }

    // ─── Agent Status ───────────────────────────────────────────────────────

    match /agent_status/{agentId} {
      allow read: if isAuth() && isNotBlocked();
      allow write: if isAuth() && request.auth.uid == agentId;
    }

    // ─── Contents ───────────────────────────────────────────────────────────

    match /contents/{contentId} {
      allow read: if isAuth() && isNotBlocked();
      allow write: if isAdmin();
    }

    // ─── Conversations ──────────────────────────────────────────────────────

    match /conversations/{conversationId} {
      allow read: if isAuth() && isNotBlocked() && (
        resource == null || request.auth.uid in resource.data.members || isAdmin()
      );
      allow create: if isAuth() && (
        // Must include self as member
        request.auth.uid in request.resource.data.members
        // Must have valid type
        && request.resource.data.type in ['admin_dm', 'admin_group', 'agent_member', 'support']
      );
      allow update: if isAuth() && isNotBlocked() && (
        // Member of the conversation
        request.auth.uid in resource.data.members
      );
      allow delete: if isAdmin();
    }

    // ─── Messages ───────────────────────────────────────────────────────────

    match /messages/{messageId} {
      allow read: if isAuth() && isNotBlocked();
      allow create: if isAuth() && isNotBlocked() && (
        request.resource.data.senderId == request.auth.uid || isAdmin()
      );
      allow update: if isAuth() && isNotBlocked() && (
        resource.data.senderId == request.auth.uid || isSuperAdmin()
      );
      allow delete: if false; // soft delete only
    }

    // ─── Notifications ──────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    // ─── Tickets ────────────────────────────────────────────────────────────

    match /tickets/{ticketId} {
      allow read: if isAuth() && isNotBlocked() && (
        resource.data.customerId == request.auth.uid || resource.data.assignedAgentId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && (
        request.resource.data.customerId == request.auth.uid || isAdmin()
      );
      allow update: if isAuth() && isNotBlocked() && (
        resource.data.assignedAgentId == request.auth.uid || isAdmin()
      );
      allow delete: if false;
    }

    // ─── Ticket Counters ────────────────────────────────────────────────────

    match /ticket_counters/{year} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Canned Responses ───────────────────────────────────────────────────

    match /canned_responses/{responseId} {
      allow read: if isAuth() && isNotBlocked();
      allow write: if isAdmin();
    }

    // ─── Bot Sessions ───────────────────────────────────────────────────────

    match /bot_sessions/{sessionId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if false;
    }

    // ─── Typing Indicators ──────────────────────────────────────────────────

    match /typing/{indicatorId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == request.resource.data.userId;
    }

    // ─── Audit Logs ─────────────────────────────────────────────────────────

    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
